{
  "name": "Tab Audio Recorder",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "processor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}