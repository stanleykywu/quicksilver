{
  "name": "Quicksilver",
  "version": "1.0",
  "version name": "1.0 beta",
  "description": "An extension that allows users to record music (audio) for any tab, and runs a machine learning detector to determine whether the music was generated by AI.",
  "manifest_version": 3,
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "processor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}